{
  "name": "media-list-site",
  "version": "1.0.0",
  "private": true,
  "description": "A simple Node.js site for managing a movie and book list.",
  "scripts": {
    "build:tailwind": "postcss src/tailwind.css -o public/tailwind.css",
    "watch:tailwind": "postcss src/tailwind.css -o public/tailwind.css --watch",
    "start": "node server.js"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.10",
    "postcss-cli": "^11.0.1",
    "tailwindcss": "^3.4.19"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "express": "^5.2.1"
  }
}
